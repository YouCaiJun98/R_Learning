# 横坐标是时间，纵坐标是投资者信心指数（investor_confidence_index）。
# 同时添加标题、横纵坐标标签。
plot(stock$时间, stock$investor_confidence_index,
type = "l",
main = "投资者信心指数走势",
xlab = "时间",
ylab = "投资者信心指数",
)
library(writexl)
set.seed(123)
# 生成时间序列
