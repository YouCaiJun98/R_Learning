install.packages("writexl")  # 第一次用才需要安装
library(writexl)
# 生成模拟天猫电视数据（完全符合题目字段要求）
set.seed(123) # 固定随机数，每次运行结果一样
tianmao_2 <- data.frame(
shop_id = sample(1001:1050, 100, replace = TRUE),    # 店铺ID
shop_name = paste0("店铺", sample(1:50, 100, TRUE)), # 店铺名
current_price = sample(500:5000, 100, replace = TRUE), # 当前价格
stock = sample(0:500, 100, replace = TRUE)           # 库存
)
# 导出为 xlsx 文件（会自动保存在你的工作目录）
write_xlsx(tianmao_2, "tianmaoTV.xlsx")
# 查看一下生成的数据
head(tianmao_2)
# 1、导入tianmaoTV.xlsx，并把数据集命名成tianmao_2，以下操作都基于tianmao_2数据集
library(readxl)
tianmao_2 <- read_excel("tianmaoTV.xlsx")
tianmao_2 <- read_excel("./data/tianmaoTV.xlsx")
# 2、提取当前价格(current_price)小于1000的所有观测
tianmao_2_sub <- subset(tianmao_2, current_price < 1000)
# 3、在数据集tianmao_2中生成一个新列，将新列命名为stock_class。
# 当库存（stock）等于0，stock_class的值为'无货'；
# 库存（stock）小于100，stock_class的值为'低库存'；
# 库存（stock）大于等于100，stock_class的值为'高库存'
tianmao_2$stock_class <- ifelse(tianmao_2$stock == 0, "无货",
ifelse(tianmao_2$stock < 100, "低库存", "高库存"))
# 4、提取tianmao_2的stock、stock_class两列
tianmao_2_stock <- tianmao_2[, c("stock", "stock_class")]
# 5、将列名为"shop_id","shop_name" 的两列删除掉
tianmao_2 <- tianmao_2[, !names(tianmao_2) %in% c("shop_id", "shop_name")]
View(tianmao_2)
