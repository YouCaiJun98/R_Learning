library(writexl)
# 固定随机数，结果可复现
set.seed(123)
# 生成 577 条天猫电视模拟数据
tianmao_2 <- data.frame(
shop_id = sample(1001:1050, 577, replace = TRUE),        # 店铺ID
shop_name = paste0("店铺", sample(1:50, 577, replace = TRUE)), # 店铺名
# ✅ 正浮点数：当前价格（比如 599.9 ~ 4999.9）
current_price = round(runif(577, min = 599.9, max = 4999.9), 2),
# ✅ 正整数：月销量
month_sales_count = sample(1:5000, 577, replace = TRUE),
# 库存（整数）
stock = sample(0:500, 577, replace = TRUE)
)
# 导出为 xlsx
write_xlsx(tianmao_2, "tianmaoTV.xlsx")
# 查看前6行 + 数据规模
head(tianmao_2)
cat("总样本数：", nrow(tianmao_2), "\n")
tianmao <- read_excel('./data/tianmaoTV.xlsx')
tianmao['total_sales'] <- tianmao$current_price * tianmao$month_sales_count
View(tianmao)
# install.packages("writexl")
library(writexl)
# 固定随机数，结果可复现
set.seed(123)
# 生成 577 条天猫电视模拟数据
tianmao_2 <- data.frame(
shop_id = sample(1001:1050, 577, replace = TRUE),
shop_name = paste0("店铺", sample(1:50, 577, replace = TRUE)),
# 原价（正浮点数，比现价高，更合理）
original_price = round(runif(577, min = 699.9, max = 5999.9), 2),
# 现价（正浮点数）
current_price = round(runif(577, min = 599.9, max = 4999.9), 2),
# 月销量（正整数）
month_sales_count = sample(1:5000, 577, replace = TRUE),
# 库存
stock = sample(0:500, 577, replace = TRUE)
)
# 导出为 xlsx
write_xlsx(tianmao_2, "tianmaoTV.xlsx")
# 查看前6行 + 数据规模
head(tianmao_2)
cat("总样本数：", nrow(tianmao_2), "\n")
library(readxl)
tianmao <- read_excel('./data/tianmaoTV.xlsx')
tianmao['total_sales'] <- tianmao$current_price * tianmao$month_sales_count
tianmao$discount <- tianmao$current_price / tianmao$original_price
View(tianmao)
