library(writexl)
# 固定随机数，保证数据可复现
set.seed(123)
# 1. 生成时间序列（2020年1月到2024年12月，共60个月度数据）
time_seq <- seq.Date(from = as.Date("2020-01-01"),
to = as.Date("2024-12-01"),
by = "month")
# 2. 生成投资者信心指数（正浮点数，模拟真实波动走势）
# 基础值50，叠加趋势+周期+随机波动，更符合真实市场数据
base <- 50
trend <- seq(0, 15, length.out = length(time_seq))  # 长期上升趋势
cycle <- 10 * sin(seq(0, 6*pi, length.out = length(time_seq)))  # 周期波动
noise <- rnorm(length(time_seq), mean = 0, sd = 3)  # 随机噪声
investor_confidence_index <- round(base + trend + cycle + noise, 2)
# 3. 生成数据框stock
stock <- data.frame(
时间 = time_seq,
investor_confidence_index = investor_confidence_index
)
# 4. 导出为stock.xlsx文件（保存在当前工作目录）
write_xlsx(stock, "stock.xlsx")
# 查看数据前6行和总样本数
head(stock)
cat("总样本数：", nrow(stock), "\n")
# 3、导入stock.xlsx数据集，生成数据框stock
library(readxl)
stock <- read_excel("./data/stock.xlsx")
plot(stock$时间, stock$investor_confidence_index,
type = "l",
main = "投资者信心指数走势",
xlab = "时间",
ylab = "投资者信心指数",
)
stock <- read_excel("./data/stock.xlsx")
