library(tidyverse)
data <- read.csv("./data/data1.csv")
library(readr)
library(dplyr)
# 1) Read TSV downloaded from cBioPortal / METABRIC
dat <- read_tsv("brca_metabric_clinical_data.tsv", show_col_types = FALSE)
library(readr)
library(dplyr)
# 1) Read TSV downloaded from cBioPortal / METABRIC
dat <- read_tsv("./data/brca_metabric_clinical_data.tsv", show_col_types = FALSE)
# 2) Keep columns that match the tutorial most closely
clean_dat <- dat %>%
transmute(
PATIENT_ID = `Patient ID`,
AGE_AT_DIAGNOSIS = `Age at Diagnosis`,
SEX = Sex,
INFERRED_MENOPAUSAL_STATE = `Inferred Menopausal State`,
LATERALITY = `Primary Tumor Laterality`,
HISTOLOGICAL_SUBTYPE = `Tumor Other Histologic Subtype`,
ER_STATUS = `ER Status`,
PR_STATUS = `PR Status`,
HER2_STATUS = `HER2 Status`,
CLAUDIN_SUBTYPE = `Pam50 + Claudin-low subtype`,
GRADE = `Neoplasm Histologic Grade`,
TUMOR_SIZE = `Tumor Size`,
TUMOR_STAGE = `Tumor Stage`,
LYMPH_NODES_EXAMINED_POSITIVE = `Lymph nodes examined positive`,
NPI = `Nottingham prognostic index`,
CHEMOTHERAPY = Chemotherapy,
HORMONE_THERAPY = `Hormone Therapy`,
RADIO_THERAPY = `Radio Therapy`,
BREAST_SURGERY = `Type of Breast Surgery`,
OS_MONTHS = `Overall Survival (Months)`,
OS_STATUS = `Overall Survival Status`,
VITAL_STATUS = `Patient's Vital Status`
) %>%
mutate(
GRADE = recode(as.character(GRADE),
"1" = "I", "1.0" = "I",
"2" = "II", "2.0" = "II",
"3" = "III", "3.0" = "III"),
TUMOR_STAGE = recode(as.character(TUMOR_STAGE),
"1" = "I-II", "1.0" = "I-II",
"2" = "I-II", "2.0" = "I-II",
"3" = "III-IV", "3.0" = "III-IV",
"4" = "III-IV", "4.0" = "III-IV",
"0" = "0", "0.0" = "0"),
OS_STATUS = recode(OS_STATUS,
"0:LIVING" = 0,
"1:DECEASED" = 1),
TreatmentOutcome = OS_STATUS
)
# 3) Export full CSV
write_csv(clean_dat, "metabric_cleaned_full.csv", na = "")
# 4) Export a 1500-row teaching version to resemble the screenshot
clean_dat_1500 <- clean_dat %>% slice(1:1500)
write_csv(clean_dat_1500, "metabric_cleaned_1500.csv", na = "")
# Optional: if you prefer TreatmentOutcome based on vital status instead,
# use this instead of 'TreatmentOutcome = OS_STATUS':
# TreatmentOutcome = if_else(VITAL_STATUS == "Living", 0, 1)
# 数据导入
data <- read.csv("./data/metabric_cleaned_1500.csv")
View(data)
# 核心变量选择
data_analysis <- data.frame(TreatmentOutcome = data$TreatmentOutcome,
AGE_AT_DIAGNOSIS = data$AGE_AT_DIAGNOSIS,
LATERALITY = data$LATERALITY,
ER_STATUS = data$ER_STATUS,
HER2_STATUS = data$HER2_STATUS,
TUMOR_STAGE = data$TUMOR_STAGE)
View(data_analysis)
library(readr)
library(dplyr)
# 1) Read TSV downloaded from cBioPortal / METABRIC
dat <- read_tsv("./data/brca_metabric_clinical_data.tsv", show_col_types = FALSE)
# 2) Keep columns that match the tutorial most closely
clean_dat <- dat %>%
transmute(
PATIENT_ID = `Patient ID`,
AGE_AT_DIAGNOSIS = `Age at Diagnosis`,
SEX = Sex,
INFERRED_MENOPAUSAL_STATE = `Inferred Menopausal State`,
LATERALITY = `Primary Tumor Laterality`,
HISTOLOGICAL_SUBTYPE = `Tumor Other Histologic Subtype`,
ER_STATUS = `ER Status`,
PR_STATUS = `PR Status`,
HER2_STATUS = `HER2 Status`,
CLAUDIN_SUBTYPE = `Pam50 + Claudin-low subtype`,
GRADE = `Neoplasm Histologic Grade`,
TUMOR_SIZE = `Tumor Size`,
TUMOR_STAGE = `Tumor Stage`,
LYMPH_NODES_EXAMINED_POSITIVE = `Lymph nodes examined positive`,
NPI = `Nottingham prognostic index`,
CHEMOTHERAPY = Chemotherapy,
HORMONE_THERAPY = `Hormone Therapy`,
RADIO_THERAPY = `Radio Therapy`,
BREAST_SURGERY = `Type of Breast Surgery`,
OS_MONTHS = `Overall Survival (Months)`,
OS_STATUS = `Overall Survival Status`,
VITAL_STATUS = `Patient's Vital Status`
) %>%
mutate(
GRADE = recode(as.character(GRADE),
"1" = "I", "1.0" = "I",
"2" = "II", "2.0" = "II",
"3" = "III", "3.0" = "III"),
TUMOR_STAGE = recode(as.character(TUMOR_STAGE),
"1" = "I-II", "1.0" = "I-II",
"2" = "I-II", "2.0" = "I-II",
"3" = "III-IV", "3.0" = "III-IV",
"4" = "III-IV", "4.0" = "III-IV",
"0" = "0", "0.0" = "0"),
OS_STATUS = recode(OS_STATUS,
"0:LIVING" = 0,
"1:DECEASED" = 1),
# TreatmentOutcome = OS_STATUS
TreatmentOutcome = if_else(VITAL_STATUS == "Living", 0, 1)
)
# 3) Export full CSV
write_csv(clean_dat, "metabric_cleaned_full.csv", na = "")
# 4) Export a 1500-row teaching version to resemble the screenshot
clean_dat_1500 <- clean_dat %>% slice(1:1500)
write_csv(clean_dat_1500, "metabric_cleaned_1500.csv", na = "")
