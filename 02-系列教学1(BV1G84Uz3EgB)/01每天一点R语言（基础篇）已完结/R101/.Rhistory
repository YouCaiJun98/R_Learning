# 构建数据
a <- 1:100
b <- c(rep("A", 30), rep("B", 30), NA, rep("C", 39))
df <- data.frame(a, b)
View(df)
# b不缺失
b[!is.na(b)]
# b不缺失
df[, !is.na(b)]
# b不缺失
df[!is.na(b)]
# b不缺失
df[!is.na(b), ]
# a介于45到50岁
df_sub2 <- df[df$a>=45 & df$a<=50, ]
View(df_sub2)
# b不缺失且不为A
df_sub3 <- df[!is.na(df$b) & df$b != "A", ]
View(df_sub3)
# a大于50且b不为B
df_sub4 <- df[df$a > 50 & df$b!="B",]
View(df_sub4)
df_sub4_ <- df[df$a > 50 & df$b != "B" & !is.na(df$b),]
View(df_sub4_)
# a大于50且b为B
df_sub5 <- df[df$a > 50 & df$b == "B",]
View(df_sub5)
df_sub5 <- df[df$a > 50 & df$b == "B" & !is.na(df$b),] # 有缺失！
View(df_sub5)
