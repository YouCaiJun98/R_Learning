library(tidyverse)
# 数据读取
data <- read_csv('./data_case_day20.csv')
# 数据选择
select(data, PID)
## 方法2
data_sub <- data %>% select(PID)
View(data_sub)
## 方法2
data_sub <- data %>% select(PID, pCR, Age) %>% select(PID, Age)
# 数据过滤
data_sub2 <- data_sub %>% dplyr::filter(Age <= 40)
# base R
data_sub3 <- data[data$Age <= 40, c("pCR", "Age")]
# 修改变量
data_new <- data %>% mutate(age_idx = Age * Age)
View(data_new)
# 修改变量
data_new <- data %>% mutate(age_idx = Age * Age) %>%
mutate(age_idx = if_else(condition = age_idx < 1000, true=1000, else=age_idx))
# 修改变量
data_new <- data %>% mutate(age_idx = Age * Age) %>%
mutate(age_idx = if_else(condition = age_idx < 1000, true=1000, false=age_idx))
View(data_new)
if_else
ifelse
# base R
data_base <- data.frame(data, age_index = data$Age * data$Age)
View(data_base)
data_base$age_index[data_base$age_index < 1000] = 1000
View(data_base)
