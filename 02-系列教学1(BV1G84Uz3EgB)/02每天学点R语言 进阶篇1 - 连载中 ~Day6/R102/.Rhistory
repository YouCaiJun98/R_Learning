library(tidyverse)
# 数据读取
data <- read_csv('./data_case_day20.csv')
# 数据选择
select(data, PID)
## 方法2
data_sub <- data %>% select(PID)
View(data_sub)
## 方法2
data_sub <- data %>% select(PID, pCR, Age) %>% select(PID, Age)
# 数据过滤
data_sub2 <- data_sub %>% dplyr::filter(Age <= 40)
# base R
data_sub3 <- data[data$Age <= 40, c("pCR", "Age")]
# 修改变量
data_new <- data %>% mutate(age_idx = Age * Age)
View(data_new)
# 修改变量
data_new <- data %>% mutate(age_idx = Age * Age) %>%
mutate(age_idx = if_else(condition = age_idx < 1000, true=1000, else=age_idx))
# 修改变量
data_new <- data %>% mutate(age_idx = Age * Age) %>%
mutate(age_idx = if_else(condition = age_idx < 1000, true=1000, false=age_idx))
View(data_new)
if_else
ifelse
# base R
data_base <- data.frame(data, age_index = data$Age * data$Age)
View(data_base)
data_base$age_index[data_base$age_index < 1000] = 1000
View(data_base)
library(tidyverse)
# 数据读取
data <- read_csv('./data_case_day20.csv')
# 数据分组
data_result <- data %>% group_by(pCR)
View(data_result)
# 数据分组
data_result <- data %>% group_by(pCR) %>%  summarize(N = n())
View(data_result)
View(data_result)
library(tidyverse)
data_result2 <- data %>% group_by(pCR) %>%  summarize(N = n(), Age_mean=mean(Age))
View(data_result2)
data_result2 <- data %>% group_by(pCR) %>%  summarize(N = n(),
Age_mean=mean(Age), Age_sd=sd(Age))
library(tidyverse)
data_result2 <- data %>% group_by(pCR) %>%  summarize(N = n(),
Age_mean=mean(Age))
data_result3 <- data %>% group_by(pCR) %>%  summarize(N = n(),
Age_mean=mean(Age), Age_sd=sd(Age))
View(data_result3)
data_result4 <- data %>% group_by(pCR) %>%  summarize(N = n(),
Age_mean=mean(Age), Age_sd=sd(Age), Age_str=paste(Age_mean, Age_sd, sep="±"))
View(data_result4)
data_result4 <- data %>% group_by(pCR) %>%  summarize(N = n(),
Age_mean=mean(Age), Age_sd=sd(Age),
Age_str=paste(round(Age_mean, 2), round(Age_sd, 2), sep="±"))
View(data_result4)
# 数据排序
data %>% arrange(Age)
# 数据排序
data %>% arrange(Age) %>% head
# 数据排序
data %>% arrange(Age) %>% head()
data %>% arrange(desc(Age)) %>% head() # 降序
data %>% arrange(Stage, desc(Age)) %>% head() # 多变量排序
# 数据抽样
data_sub <- data %>%  sample_frac(0.3)
data_sub2 <- data %>%  sample_n(50) # 按数量抽样
